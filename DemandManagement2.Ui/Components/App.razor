<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["DemandManagement2.Ui.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="_content/Blazor-ApexCharts/js/apex-charts.min.js"></script>
    <script src="_content/Blazor-ApexCharts/js/blazor-apex-charts.js"></script>
    <script>
        window.downloadFile = function (fileName, contentType, base64) {
            var link = document.createElement('a');
            link.href = 'data:' + contentType + ';base64,' + base64;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };

        window.setPrDragRef = function (dotNetRef) {
            window._prDotNetRef = dotNetRef;

            if (window._prDragInitialized) return;
            window._prDragInitialized = true;

            var dragId = null;

            function nearestCard(el) {
                while (el && !el.dataset.prId) el = el.parentElement;
                return (el && el.dataset.prId) ? el : null;
            }

            document.addEventListener('dragstart', function (e) {
                var card = nearestCard(e.target);
                if (!card) return;
                dragId = card.dataset.prId;
                e.dataTransfer.setData('text/plain', dragId);
                e.dataTransfer.effectAllowed = 'move';
                setTimeout(function () { card.classList.add('dm-pr-card--dragging'); }, 0);
            });

            document.addEventListener('dragend', function () {
                document.querySelectorAll('.dm-pr-card--dragging, .dm-pr-card--dragover')
                    .forEach(function (el) { el.classList.remove('dm-pr-card--dragging', 'dm-pr-card--dragover'); });
                dragId = null;
            });

            document.addEventListener('dragover', function (e) {
                if (!dragId) return;
                if (nearestCard(e.target)) {
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                }
            });

            document.addEventListener('dragenter', function (e) {
                if (!dragId) return;
                var card = nearestCard(e.target);
                document.querySelectorAll('.dm-pr-card--dragover')
                    .forEach(function (el) { el.classList.remove('dm-pr-card--dragover'); });
                if (card && card.dataset.prId !== dragId) {
                    card.classList.add('dm-pr-card--dragover');
                }
            });

            document.addEventListener('drop', function (e) {
                var card = nearestCard(e.target);
                var fromId = dragId;
                document.querySelectorAll('.dm-pr-card--dragging, .dm-pr-card--dragover')
                    .forEach(function (el) { el.classList.remove('dm-pr-card--dragging', 'dm-pr-card--dragover'); });
                dragId = null;
                if (card && fromId && card.dataset.prId !== fromId) {
                    e.preventDefault();
                    if (window._prDotNetRef) {
                        window._prDotNetRef.invokeMethodAsync('OnCardDropped', fromId, card.dataset.prId);
                    }
                }
            });
        };
    </script>
</body>

</html>
