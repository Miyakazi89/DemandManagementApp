@page "/capacity"
@rendermode InteractiveServer
@inject DemandManagement2.Ui.Services.DemandApiClient Api
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<div class="dm-page">
    <div class="dm-page__header">
        <div>
            <div class="dm-pill">Resources</div>
            <h1 class="dm-title">Capacity Planning</h1>
            <p class="dm-subtitle">Manage resources and track capacity allocation across demands.</p>
        </div>
        <div class="dm-actions">
            <a href="/dashboard" class="dm-btn dm-btn--ghost">Dashboard</a>
            <a href="/demands" class="dm-btn dm-btn--ghost">Demands</a>
            @if (_hasAccess)
            {
                <button class="dm-btn dm-btn--primary" @onclick="() => _showAddResource = true">+ Add Resource</button>
            }
        </div>
    </div>

    @if (!_hasAccess)
    {
        <div class="dm-access-denied">
            <div class="dm-access-denied__icon">&#128274;</div>
            <div class="dm-access-denied__title">Access Restricted</div>
            <div class="dm-access-denied__msg">Capacity Planning is available to <strong>Admin</strong> and <strong>Assessor</strong> roles only. As a Requester, you can submit and track your demands from the <a href="/demands">Demand Requests</a> page.</div>
            <a href="/demands" class="dm-btn dm-btn--primary">Go to My Demands</a>
        </div>
    }
    else if (_summary is null)
    {
        <div class="dm-loading">Loading capacity data...</div>
    }
    else
    {
        <!-- KPI Cards -->
        <div class="dm-grid dm-grid--4 dm-gap">
            <div class="dm-kpi-card">
                <div class="dm-kpi-label">Total Resources</div>
                <div class="dm-kpi-value">@_summary.TotalResources</div>
            </div>
            <div class="dm-kpi-card">
                <div class="dm-kpi-label">Total Capacity (hrs)</div>
                <div class="dm-kpi-value">@_summary.TotalCapacityHours</div>
            </div>
            <div class="dm-kpi-card dm-kpi-card--warning">
                <div class="dm-kpi-label">Allocated (hrs)</div>
                <div class="dm-kpi-value">@_summary.AllocatedHours</div>
            </div>
            <div class="dm-kpi-card dm-kpi-card--success">
                <div class="dm-kpi-label">Available (hrs)</div>
                <div class="dm-kpi-value">@_summary.AvailableHours</div>
            </div>
        </div>

        <div class="dm-grid dm-grid--2 dm-gap dm-mt">
            <!-- Department Breakdown -->
            <div class="dm-card">
                <div class="dm-card__header">
                    <div>
                        <div class="dm-card__title">Capacity by Department</div>
                        <div class="dm-card__hint">Current month allocation breakdown</div>
                    </div>
                </div>

                @if (_summary.ByDepartment.Count == 0)
                {
                    <div class="dm-empty">No departments found.</div>
                }
                else
                {
                    <div class="dm-dept-list">
                        @foreach (var dept in _summary.ByDepartment)
                        {
                            var pct = dept.CapacityHours > 0 ? (int)((double)dept.AllocatedHours / dept.CapacityHours * 100) : 0;
                            <div class="dm-dept-row">
                                <div class="dm-dept-name">@dept.Department</div>
                                <div class="dm-dept-bar">
                                    <div class="dm-dept-bar__fill" style="width: @pct%"></div>
                                </div>
                                <div class="dm-dept-stats">
                                    <span>@dept.AllocatedHours / @dept.CapacityHours hrs</span>
                                    <span class="dm-pct">@pct%</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Resources List -->
            <div class="dm-card">
                <div class="dm-card__header">
                    <div>
                        <div class="dm-card__title">Resources</div>
                        <div class="dm-card__hint">Team members and their capacity</div>
                    </div>
                    <span class="dm-badge dm-badge--info">@(_resources?.Count ?? 0) Active</span>
                </div>

                @if (_resources is null || _resources.Count == 0)
                {
                    <div class="dm-empty">No resources added yet.</div>
                }
                else
                {
                    <div class="dm-resource-list">
                        @foreach (var r in _resources)
                        {
                            <div class="dm-resource-row">
                                <div class="dm-resource-info">
                                    <div class="dm-resource-name">@r.Name</div>
                                    <div class="dm-resource-role">@r.Role - @r.Department</div>
                                </div>
                                <div class="dm-resource-cap">
                                    <span class="dm-pillSmall">@r.CapacityHoursPerMonth hrs/mo</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Allocations -->
        <div class="dm-card dm-mt">
            <div class="dm-card__header">
                <div>
                    <div class="dm-card__title">Current Allocations</div>
                    <div class="dm-card__hint">Resource assignments to demands this month</div>
                </div>
                <button class="dm-btn dm-btn--ghost" @onclick="() => _showAddAllocation = true">+ Allocate</button>
            </div>

            @if (_allocations is null || _allocations.Count == 0)
            {
                <div class="dm-empty">No allocations for this period.</div>
            }
            else
            {
                <div class="dm-alloc-list">
                    @foreach (var a in _allocations)
                    {
                        <div class="dm-alloc-row">
                            <div class="dm-alloc-resource">@a.ResourceName</div>
                            <div class="dm-alloc-demand">@a.DemandTitle</div>
                            <div class="dm-alloc-hours">@a.AllocatedHours hrs</div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Project Resources -->
        <div class="dm-card dm-mt">
            <div class="dm-card__header">
                <div>
                    <div class="dm-card__title">Project Resources</div>
                    <div class="dm-card__hint">Financial, physical, information &amp; governance resources required by demands &mdash; <span class="dm-pr-drag-hint">drag cards to reorder</span></div>
                </div>
                <div class="dm-pr-toolbar">
                    <div class="dm-pr-tabs">
                        <button class="dm-pr-tab @(_prFilterType == "" ? "dm-pr-tab--active" : "")" @onclick='() => _prFilterType = ""'>All</button>
                        <button class="dm-pr-tab dm-pr-tab--fin @(_prFilterType == "Financial" ? "dm-pr-tab--active" : "")" @onclick='() => _prFilterType = "Financial"'>Financial</button>
                        <button class="dm-pr-tab dm-pr-tab--phys @(_prFilterType == "Physical" ? "dm-pr-tab--active" : "")" @onclick='() => _prFilterType = "Physical"'>Physical</button>
                        <button class="dm-pr-tab dm-pr-tab--info @(_prFilterType == "InformationKnowledge" ? "dm-pr-tab--active" : "")" @onclick='() => _prFilterType = "InformationKnowledge"'>Info &amp; Knowledge</button>
                        <button class="dm-pr-tab dm-pr-tab--gov @(_prFilterType == "GovernanceSupport" ? "dm-pr-tab--active" : "")" @onclick='() => _prFilterType = "GovernanceSupport"'>Governance</button>
                    </div>
                    <button class="dm-btn dm-btn--ghost" @onclick="OpenPrModal">+ Add Resource</button>
                </div>
            </div>

            @{
                var prFiltered = GetFilteredPr();
                var prTotalCost = prFiltered.Where(r => r.EstimatedCost.HasValue).Sum(r => r.EstimatedCost!.Value);
            }

            @if (_projectResources?.Count > 0)
            {
                <div class="dm-pr-kpis">
                    <div class="dm-pr-kpi">
                        <span class="dm-pr-kpi__label">Total Items</span>
                        <span class="dm-pr-kpi__value">@prFiltered.Count</span>
                    </div>
                    <div class="dm-pr-kpi dm-pr-kpi--fin">
                        <span class="dm-pr-kpi__label">Financial</span>
                        <span class="dm-pr-kpi__value">@prFiltered.Count(r => r.ResourceType == "Financial")</span>
                    </div>
                    <div class="dm-pr-kpi dm-pr-kpi--phys">
                        <span class="dm-pr-kpi__label">Physical</span>
                        <span class="dm-pr-kpi__value">@prFiltered.Count(r => r.ResourceType == "Physical")</span>
                    </div>
                    <div class="dm-pr-kpi dm-pr-kpi--info">
                        <span class="dm-pr-kpi__label">Info &amp; Knowledge</span>
                        <span class="dm-pr-kpi__value">@prFiltered.Count(r => r.ResourceType == "InformationKnowledge")</span>
                    </div>
                    <div class="dm-pr-kpi dm-pr-kpi--gov">
                        <span class="dm-pr-kpi__label">Governance</span>
                        <span class="dm-pr-kpi__value">@prFiltered.Count(r => r.ResourceType == "GovernanceSupport")</span>
                    </div>
                    @if (prTotalCost > 0)
                    {
                        <div class="dm-pr-kpi dm-pr-kpi--cost">
                            <span class="dm-pr-kpi__label">Est. Total Cost</span>
                            <span class="dm-pr-kpi__value">@prTotalCost.ToString("N0")</span>
                        </div>
                    }
                </div>
            }

            @if (prFiltered.Count == 0)
            {
                <div class="dm-empty">No project resources yet. Click <strong>+ Add Resource</strong> to add one.</div>
            }
            else
            {
                @if (string.IsNullOrEmpty(_prFilterType))
                {
                    @foreach (var grp in prFiltered.GroupBy(r => r.ResourceType).OrderBy(g => PrTypeOrder(g.Key)))
                    {
                        <div class="dm-pr-group">
                            <div class="dm-pr-group__header">
                                <span class="dm-pr-badge dm-pr-badge--@PrTypeCss(grp.Key)">@PrTypeLabel(grp.Key)</span>
                                <span class="dm-pr-group__count">@grp.Count() item@(grp.Count() != 1 ? "s" : "")</span>
                            </div>
                            <div class="dm-pr-cards">
                                @foreach (var r in grp) { @PrCard(r) }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="dm-pr-cards">
                        @foreach (var r in prFiltered) { @PrCard(r) }
                    </div>
                }
            }
        </div>
    }

    <!-- Add Resource Modal -->
    @if (_showAddResource)
    {
        <div class="dm-modal-overlay" @onclick="() => _showAddResource = false">
            <div class="dm-modal" @onclick:stopPropagation="true">
                <div class="dm-modal__header">
                    <div class="dm-modal__title">Add Resource</div>
                    <button class="dm-modal__close" @onclick="() => _showAddResource = false">&times;</button>
                </div>
                <div class="dm-form">
                    <div class="dm-form-row">
                        <label>Name</label>
                        <input class="dm-input" @bind="_newResource.Name" placeholder="Full name" />
                    </div>
                    <div class="dm-form-row">
                        <label>Role</label>
                        <input class="dm-input" @bind="_newResource.Role" placeholder="e.g. Developer, Analyst" />
                    </div>
                    <div class="dm-form-row">
                        <label>Department</label>
                        <input class="dm-input" @bind="_newResource.Department" placeholder="e.g. IT, Operations" />
                    </div>
                    <div class="dm-form-row">
                        <label>Capacity (hrs/month)</label>
                        <input class="dm-input" type="number" @bind="_newResource.CapacityHoursPerMonth" />
                    </div>
                    <div class="dm-form-actions">
                        <button class="dm-btn dm-btn--primary" @onclick="AddResource">Save Resource</button>
                        <span class="dm-msg">@_msgR</span>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Add Allocation Modal -->
    @if (_showAddAllocation)
    {
        <div class="dm-modal-overlay" @onclick="() => _showAddAllocation = false">
            <div class="dm-modal" @onclick:stopPropagation="true">
                <div class="dm-modal__header">
                    <div class="dm-modal__title">Allocate Resource</div>
                    <button class="dm-modal__close" @onclick="() => _showAddAllocation = false">&times;</button>
                </div>
                <div class="dm-form">
                    <div class="dm-form-row">
                        <label>Resource</label>
                        <select class="dm-input dm-select" @bind="_newAllocation.ResourceId">
                            <option value="@Guid.Empty">-- Select Resource --</option>
                            @if (_resources is not null)
                            {
                                @foreach (var r in _resources)
                                {
                                    <option value="@r.Id">@r.Name (@r.Role)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="dm-form-row">
                        <label>Demand</label>
                        <select class="dm-input dm-select" @bind="_newAllocation.DemandRequestId">
                            <option value="@Guid.Empty">-- Select Demand --</option>
                            @if (_demands is not null)
                            {
                                @foreach (var d in _demands)
                                {
                                    <option value="@d.Id">@d.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="dm-form-row">
                        <label>Hours</label>
                        <input class="dm-input" type="number" @bind="_newAllocation.AllocatedHours" />
                    </div>
                    <div class="dm-form-row">
                        <label>Month</label>
                        <input class="dm-input" type="number" min="1" max="12" @bind="_newAllocation.Month" />
                    </div>
                    <div class="dm-form-row">
                        <label>Year</label>
                        <input class="dm-input" type="number" @bind="_newAllocation.Year" />
                    </div>
                    <div class="dm-form-actions">
                        <button class="dm-btn dm-btn--primary" @onclick="AddAllocation">Save Allocation</button>
                        <span class="dm-msg">@_msgA</span>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Add Project Resource Modal -->
    @if (_showAddPr)
    {
        <div class="dm-modal-overlay" @onclick="() => _showAddPr = false">
            <div class="dm-modal dm-modal--wide" @onclick:stopPropagation="true">
                <div class="dm-modal__header">
                    <div class="dm-modal__title">Add Project Resource</div>
                    <button class="dm-modal__close" @onclick="() => _showAddPr = false">&times;</button>
                </div>
                <div class="dm-form">
                    <div class="dm-form-row">
                        <label>Demand *</label>
                        <select class="dm-input dm-select" @bind="_newPr.DemandRequestId">
                            <option value="@Guid.Empty">-- Select Demand --</option>
                            @if (_demands is not null)
                            {
                                @foreach (var d in _demands)
                                {
                                    <option value="@d.Id">@d.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="dm-form-row">
                        <label>Resource Type *</label>
                        <select class="dm-input dm-select" @bind="_newPr.ResourceType">
                            <option value="Financial">Financial – Budget &amp; costs</option>
                            <option value="Physical">Physical – Equipment &amp; items</option>
                            <option value="InformationKnowledge">Information &amp; Knowledge – Docs &amp; data</option>
                            <option value="GovernanceSupport">Governance &amp; Support – Frameworks &amp; processes</option>
                        </select>
                    </div>
                    <div class="dm-pr-hint">@PrTypeHint(_newPr.ResourceType)</div>
                    <div class="dm-form-row">
                        <label>Name *</label>
                        <input class="dm-input" @bind="_newPr.Name" placeholder="@PrNamePlaceholder(_newPr.ResourceType)" />
                    </div>
                    <div class="dm-form-row">
                        <label>Description</label>
                        <textarea class="dm-input dm-textarea" @bind="_newPr.Description" placeholder="Describe this resource requirement..."></textarea>
                    </div>
                    @if (_newPr.ResourceType == "Financial")
                    {
                        <div class="dm-form-2col">
                            <div class="dm-form-row">
                                <label>Estimated Cost</label>
                                <input class="dm-input" type="number" step="0.01" @bind="_newPr.EstimatedCost" placeholder="0.00" />
                            </div>
                            <div class="dm-form-row">
                                <label>Currency</label>
                                <select class="dm-input dm-select" @bind="_newPr.Currency">
                                    <option value="ZAR">ZAR</option>
                                    <option value="USD">USD</option>
                                    <option value="EUR">EUR</option>
                                    <option value="GBP">GBP</option>
                                </select>
                            </div>
                        </div>
                        <div class="dm-form-row">
                            <label>Vendor / Supplier</label>
                            <input class="dm-input" @bind="_newPr.Supplier" placeholder="e.g. Microsoft, Contractor name" />
                        </div>
                    }
                    @if (_newPr.ResourceType == "Physical")
                    {
                        <div class="dm-form-row">
                            <label>Quantity</label>
                            <input class="dm-input" type="number" @bind="_newPr.Quantity" placeholder="e.g. 10" />
                        </div>
                        <div class="dm-form-row">
                            <label>Vendor / Supplier</label>
                            <input class="dm-input" @bind="_newPr.Supplier" placeholder="e.g. Dell, HP, Local vendor" />
                        </div>
                    }
                    @if (_newPr.ResourceType == "InformationKnowledge" || _newPr.ResourceType == "GovernanceSupport")
                    {
                        <div class="dm-form-row">
                            <label>Owner / Responsible</label>
                            <input class="dm-input" @bind="_newPr.Owner" placeholder="e.g. Business Analyst, PMO" />
                        </div>
                    }
                    <div class="dm-form-row">
                        <label>Status</label>
                        <select class="dm-input dm-select" @bind="_newPr.Status">
                            <option value="Pending">Pending</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Approved">Approved</option>
                            <option value="Available">Available</option>
                            <option value="Acquired">Acquired</option>
                            <option value="In Place">In Place</option>
                        </select>
                    </div>
                    <div class="dm-form-row">
                        <label>Notes</label>
                        <textarea class="dm-input dm-textarea" @bind="_newPr.Notes" placeholder="Additional notes..."></textarea>
                    </div>
                    <div class="dm-form-actions">
                        <button class="dm-btn dm-btn--primary" @onclick="SaveProjectResource">Save Resource</button>
                        <button class="dm-btn dm-btn--ghost" @onclick="() => _showAddPr = false">Cancel</button>
                        @if (!string.IsNullOrEmpty(_msgPr))
                        {
                            <span class="dm-msg @(_msgPr.StartsWith("Error") ? "dm-msg--error" : "")">@_msgPr</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Delete Project Resource Confirm -->
    @if (_prDeleteId.HasValue)
    {
        <div class="dm-modal-overlay" @onclick="() => _prDeleteId = null">
            <div class="dm-modal" @onclick:stopPropagation="true" style="max-width:380px;">
                <div class="dm-modal__header">
                    <div class="dm-modal__title">Delete Resource?</div>
                    <button class="dm-modal__close" @onclick="() => _prDeleteId = null">&times;</button>
                </div>
                <p style="color:rgba(255,255,255,.7);margin:0 0 20px;">This will permanently remove this resource. This cannot be undone.</p>
                <div class="dm-form-actions">
                    <button class="dm-btn dm-btn--danger" @onclick="ConfirmDeletePr">Delete</button>
                    <button class="dm-btn dm-btn--ghost" @onclick="() => _prDeleteId = null">Cancel</button>
                    @if (!string.IsNullOrEmpty(_msgPrDel))
                    {
                        <span class="dm-msg dm-msg--error">@_msgPrDel</span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DemandManagement2.Ui.Services.CapacitySummary? _summary;
    private List<DemandManagement2.Ui.Services.ResourceItem>? _resources;
    private List<DemandManagement2.Ui.Services.AllocationItem>? _allocations;
    private List<DemandManagement2.Ui.Services.DemandListItem>? _demands;

    private bool _showAddResource;
    private bool _showAddAllocation;
    private bool _hasAccess = true;
    private DemandManagement2.Ui.Services.CreateResourceRequest _newResource = new();
    private DemandManagement2.Ui.Services.CreateAllocationRequest _newAllocation = new()
    {
        Month = DateTime.Now.Month,
        Year = DateTime.Now.Year
    };
    private string _msgR = "";
    private string _msgA = "";

    // Project Resources
    private List<DemandManagement2.Ui.Services.ProjectResourceItem>? _projectResources;
    private bool _showAddPr;
    private string _msgPr = "";
    private string _prFilterType = "";
    private Guid? _prDeleteId;
    private string _msgPrDel = "";
    private DemandManagement2.Ui.Services.CreateProjectResourceRequest _newPr = new();

    // Drag-and-drop (JS-based)
    private DotNetObjectReference<Capacity>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var role = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        _hasAccess = role == "Admin" || role == "Assessor";

        if (_hasAccess)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _summary = await Api.GetCapacitySummary();
        _resources = await Api.GetResources();
        _allocations = await Api.GetAllocations();
        _demands = await Api.GetDemands();
        _projectResources = await Api.GetProjectResources();
    }

    private async Task AddResource()
    {
        try
        {
            _msgR = "Saving...";
            StateHasChanged();
            await Api.CreateResource(_newResource);
            _newResource = new();
            _showAddResource = false;
            await LoadData();
            _msgR = "";
        }
        catch (Exception ex)
        {
            _msgR = $"Error: {ex.Message}";
        }
    }

    private async Task AddAllocation()
    {
        try
        {
            _msgA = "Saving...";
            StateHasChanged();
            await Api.CreateAllocation(_newAllocation);
            _newAllocation = new() { Month = DateTime.Now.Month, Year = DateTime.Now.Year };
            _showAddAllocation = false;
            await LoadData();
            _msgA = "";
        }
        catch (Exception ex)
        {
            _msgA = $"Error: {ex.Message}";
        }
    }

    // ---- Project Resource methods ----
    private void OpenPrModal()
    {
        _newPr = new();
        _msgPr = "";
        _showAddPr = true;
    }

    private List<DemandManagement2.Ui.Services.ProjectResourceItem> GetFilteredPr()
    {
        var list = _projectResources ?? new();
        if (!string.IsNullOrEmpty(_prFilterType))
            list = list.Where(r => r.ResourceType == _prFilterType).ToList();
        return list;
    }

    private async Task SaveProjectResource()
    {
        if (_newPr.DemandRequestId == Guid.Empty) { _msgPr = "Error: Please select a demand."; return; }
        if (string.IsNullOrWhiteSpace(_newPr.Name)) { _msgPr = "Error: Name is required."; return; }
        try
        {
            _msgPr = "Saving...";
            StateHasChanged();
            await Api.CreateProjectResource(_newPr);
            _showAddPr = false;
            _msgPr = "";
            _newPr = new();
            _projectResources = await Api.GetProjectResources();
        }
        catch (Exception ex)
        {
            _msgPr = $"Error: {ex.Message}";
        }
    }

    private void RequestDeletePr(Guid id) { _prDeleteId = id; _msgPrDel = ""; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_hasAccess) return;
        _dotNetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("setPrDragRef", _dotNetRef);
    }

    [Microsoft.JSInterop.JSInvokable]
    public async Task OnCardDropped(string dragIdStr, string targetIdStr)
    {
        if (!Guid.TryParse(dragIdStr, out var dragId) || !Guid.TryParse(targetIdStr, out var targetId)) return;

        var list = (_projectResources ?? new()).ToList();
        var dragIdx = list.FindIndex(r => r.Id == dragId);
        if (dragIdx < 0) return;

        var dragItem = list[dragIdx];
        list.RemoveAt(dragIdx);
        var targetIdx = list.FindIndex(r => r.Id == targetId);
        if (targetIdx < 0) targetIdx = list.Count;
        list.Insert(targetIdx, dragItem);

        _projectResources = list;
        await InvokeAsync(StateHasChanged);

        var reorderData = list.Select((r, i) => new DemandManagement2.Ui.Services.ReorderProjectResourceRequest(r.Id, i)).ToList();
        try { await Api.ReorderProjectResources(reorderData); }
        catch { }
    }

    public void Dispose() => _dotNetRef?.Dispose();

    private async Task ConfirmDeletePr()
    {
        if (!_prDeleteId.HasValue) return;
        try
        {
            _msgPrDel = "Deleting...";
            StateHasChanged();
            await Api.DeleteProjectResource(_prDeleteId.Value);
            _prDeleteId = null;
            _projectResources = await Api.GetProjectResources();
        }
        catch (Exception ex)
        {
            _msgPrDel = $"Error: {ex.Message}";
        }
    }

    private RenderFragment PrCard(DemandManagement2.Ui.Services.ProjectResourceItem r) => __builder =>
    {
        <div class="dm-pr-card" draggable="true" data-pr-id="@r.Id">
            <div class="dm-pr-card__drag-handle" title="Drag to reorder">&#9776;</div>
            <div class="dm-pr-card__top">
                <span class="dm-pr-badge dm-pr-badge--@PrTypeCss(r.ResourceType)">@PrTypeLabel(r.ResourceType)</span>
                <span class="dm-pr-status dm-pr-status--@PrStatusCss(r.Status)">@r.Status</span>
            </div>
            <div class="dm-pr-card__name">@r.Name</div>
            @if (!string.IsNullOrEmpty(r.Description))
            {
                <div class="dm-pr-card__desc">@r.Description</div>
            }
            <div class="dm-pr-card__details">
                @if (r.EstimatedCost.HasValue)
                {
                    <div class="dm-pr-detail"><span class="dm-pr-detail__label">Est. Cost</span><span class="dm-pr-detail__val dm-pr-cost">@(r.Currency ?? "ZAR") @r.EstimatedCost.Value.ToString("N2")</span></div>
                }
                @if (r.Quantity.HasValue)
                {
                    <div class="dm-pr-detail"><span class="dm-pr-detail__label">Quantity</span><span class="dm-pr-detail__val">@r.Quantity</span></div>
                }
                @if (!string.IsNullOrEmpty(r.Supplier))
                {
                    <div class="dm-pr-detail"><span class="dm-pr-detail__label">Vendor</span><span class="dm-pr-detail__val">@r.Supplier</span></div>
                }
                @if (!string.IsNullOrEmpty(r.Owner))
                {
                    <div class="dm-pr-detail"><span class="dm-pr-detail__label">Owner</span><span class="dm-pr-detail__val">@r.Owner</span></div>
                }
                @if (!string.IsNullOrEmpty(r.Notes))
                {
                    <div class="dm-pr-detail"><span class="dm-pr-detail__label">Notes</span><span class="dm-pr-detail__val">@r.Notes</span></div>
                }
            </div>
            <div class="dm-pr-card__footer">
                <a href="/demands/@r.DemandRequestId" class="dm-pr-card__demand">@r.DemandTitle</a>
                <button class="dm-pr-delete" @onclick="() => RequestDeletePr(r.Id)">Delete</button>
            </div>
        </div>
    };

    private string PrTypeLabel(string t) => t switch
    {
        "Financial" => "Financial",
        "Physical" => "Physical",
        "InformationKnowledge" => "Info & Knowledge",
        "GovernanceSupport" => "Governance & Support",
        _ => t
    };

    private string PrTypeCss(string t) => t switch
    {
        "Financial" => "fin",
        "Physical" => "phys",
        "InformationKnowledge" => "info",
        "GovernanceSupport" => "gov",
        _ => "fin"
    };

    private int PrTypeOrder(string t) => t switch { "Financial" => 0, "Physical" => 1, "InformationKnowledge" => 2, "GovernanceSupport" => 3, _ => 99 };

    private string PrStatusCss(string s) => s switch
    {
        "Pending" => "pending",
        "In Progress" => "inprogress",
        "Approved" => "approved",
        "Available" or "Acquired" or "In Place" => "done",
        _ => "pending"
    };

    private string PrTypeHint(string t) => t switch
    {
        "Financial" => "Budget required: software/licensing costs, contractor fees, training, marketing, equipment purchases.",
        "Physical" => "Physical items required: laptops, workstations, servers, office equipment.",
        "InformationKnowledge" => "Data & insights needed: business requirements, user stories, process maps, policies, reports.",
        "GovernanceSupport" => "Structures that guide the project: risk frameworks, change management, QA standards, governance committees.",
        _ => ""
    };

    private string PrNamePlaceholder(string t) => t switch
    {
        "Financial" => "e.g. AWS Cloud Licensing, Contractor Fees",
        "Physical" => "e.g. Developer Laptops, Network Equipment",
        "InformationKnowledge" => "e.g. Business Requirements Document, Process Map",
        "GovernanceSupport" => "e.g. Risk Management Framework, Change Management Process",
        _ => "Resource name"
    };
}


<style>
:root{
