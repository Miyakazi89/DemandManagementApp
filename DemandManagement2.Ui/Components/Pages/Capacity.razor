  padding-bottom: 4px;
  margin-bottom: 2px;
  border-bottom: 1px dashed rgba(255,255,255,.08);
  transition: color .15s;
  letter-spacing: 2px;
}
.dm-pr-card__drag-handle:active{ cursor: grabbing; }
.dm-pr-card:hover .dm-pr-card__drag-handle{ color: rgba(255,255,255,.55); }

/* Applied by JS, not Blazor — no re-render needed */
.dm-pr-card--dragging{
  opacity: 0.3;
  border-style: dashed !important;
}
.dm-pr-card--dragover{
  border-color: #ffcd11 !important;
  border-style: solid !important;
  box-shadow: 0 0 0 3px rgba(255,205,17,.2), 0 8px 24px rgba(0,0,0,.3);
