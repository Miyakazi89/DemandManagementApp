}

@@media (max-width: 900px){
  .dm-grid--4{ grid-template-columns: repeat(2, 1fr); }
  .dm-pr-toolbar{ flex-direction: column; align-items: flex-start; }
}
@@media (max-width: 700px){
  .dm-grid--2, .dm-grid--4{ grid-template-columns: 1fr; }
  .dm-page__header{ flex-direction: column; }
  .dm-alloc-row{ grid-template-columns: 1fr; }
  .dm-pr-cards{ grid-template-columns: 1fr; }
  .dm-form-2col{ grid-template-columns: 1fr; }
  .dm-modal--wide{ min-width: unset; }
}
</style>
